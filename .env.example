GROQ_API_KEY=your_groq_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here
# Optional extra Pexels keys — the search rotates to the next when one hits its
# hourly rate limit (~200 req/hr each), so big projects don't go Pexels-dark.
# Use numbered vars and/or a comma list; all are pooled with PEXELS_API_KEY.
# PEXELS_API_KEY_2=second_pexels_key
# PEXELS_API_KEY_3=third_pexels_key
# PEXELS_API_KEYS=keyA,keyB,keyC
PIXABAY_API_KEY=your_pixabay_api_key_here
# YouTube Data API v3 key (Google Cloud Console).
# Used ONLY to check HD/SD and drop SD clips — the YouTube *search* is done with
# yt-dlp + keywords, not this API. Quota: 10,000 units/day.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── YouTube cookies ──────────────────────────────────────────────────────────
# SERVER/Docker: drop a cookies.txt (Netscape format, from a browser logged into
# YouTube) into a `cookies/` folder — it's AUTO-DETECTED (any *.txt) and wins
# over YT_COOKIE_BROWSER, so you usually don't need to set anything here. Mount
# it with `-v "$PWD/cookies:/app/cookies:ro"`. Required for reliable YouTube
# results from a datacenter IP. See deploy/README.md.
# YT_COOKIE_FILE=/app/cookies/www.youtube.com_cookies.txt   # optional explicit path
# Desktop only (NOT on a server — no browser there):
# YT_COOKIE_BROWSER=firefox

# Optional second Groq key — used when the first hits rate limits.
# GROQ_API_KEY_2=your_second_groq_api_key_here

# Optional free fallback when Groq is rate-limited.
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_KEY_2=your_second_openrouter_api_key_here

# Optional PAID, higher-quality model — deepseek-v4-pro routed THROUGH OpenRouter.
# Paste an OpenRouter API key here (not a direct DeepSeek key). When set it's used
# FIRST for every AI step (shot list, ranking, keywords, context segmenter), with
# Groq/OpenRouter free models as automatic fallbacks. Groq is still required (it
# does the transcription).
# DEEPSEEK_API_KEY=your_openrouter_api_key_here
# Two tiers, switched per call with the SAME key:
#   fast  → high-volume loop calls (shot slicing, ranking) — flash, no reasoning
#   smart → once-per-video global passes (topic, themes, structural pre-pass)
#           — pro WITH reasoning (synthesis). Single calls, so no rate-limit risk.
# DEEPSEEK_MODEL_FAST=deepseek/deepseek-v4-flash
# DEEPSEEK_MODEL_SMART=deepseek/deepseek-v4-pro
# Emergency override of the per-tier reasoning default (on/off). Leave unset.
# DEEPSEEK_REASONING=
# max_tokens floor (reasoning, when on, counts against it). Usually fine at 8000.
# DEEPSEEK_MAX_TOKENS=8000

# Optional — Freesound SFX download for text overlays.
# FREESOUND_API_KEY=your_freesound_api_key_here

# ── Pipeline feature toggles (default off) ───────────────────────────────────
# Context-aware keywords: pre-scan the transcript into subject segments and
# anchor each shot's queries to the subject in play at that timestamp.
# ENABLE_CONTEXT_AWARE_KEYWORDS=false
# Auto-selection: after ranking, auto-bind the top-ranked clip to each shot.
# ENABLE_AUTO_SELECTION=false
# Variety guard for auto-select: avoid reusing the same clip within this many
# recent shots (picks the next-best alternative instead). 0 disables.
# AUTO_SELECT_LOOKBACK=3
# Auto-select binds multiple clips per shot, scaled by duration (one clip per
# this many seconds), so faceless videos get a fresh visual every few seconds.
# Even short shots get MIN clips (alternatives the editor can choose from).
# AUTO_SELECT_SECONDS_PER_CLIP=5
# AUTO_SELECT_MIN_CLIPS=2
# AUTO_SELECT_MAX_CLIPS=8
# Segments per shot-list LLM call. Each block = one call, processed
# sequentially — raise this on long transcripts to cut the number of calls
# (and the rate-limit pressure / wait time). Default 20.
# DIRECTOR_BLOCK_SIZE=20

# Paid-only mode: if a DeepSeek call fails, wait & retry (longer backoff) instead
# of falling back to the free Groq/OpenRouter tiers.
# DEEPSEEK_NO_FALLBACK=true
# OpenRouter provider routing for the DeepSeek calls: only route to providers that
# support our params (json mode + reasoning), and on an empty/garbage response
# exclude that provider and retry on a different one. Set =false if you ever get
# "no available providers".
# OPENROUTER_REQUIRE_PARAMETERS=true
# OPENROUTER_PROVIDER_SORT=throughput   # optional: prefer throughput/latency/price

# ── Fully-automatic mode: which sources & how many videos per source ──────────
# AUTO_USE_PEXELS=true      # Pexels on/off (needs PEXELS_API_KEY)
# AUTO_PEXELS_NUM=3         # videos per query from Pexels
# AUTO_USE_YOUTUBE=true     # YouTube classic (yt-dlp) search on/off
# AUTO_YOUTUBE_NUM=4        # videos per query from YouTube
# AUTO_USE_LIBRARY=true     # also pull from your local Clip Library (free, no API)
# AUTO_LIBRARY_NUM=5        # library results added per shot
# AUTO_MIN_HEIGHT=720       # minimum height (HD); 0 = no filter
# ENABLE_QA_REVIEW=true     # run the Step 5.5 QA review in auto/headless mode (false skips it)
# AUTO_FILL=true            # before QA, aggressively re-fetch any shot with no
#                           # clip (multi-pass, YouTube-first) so nearly every
#                           # shot ends up with footage. Bot: /settings → Auto-fill.
# AUTO_REFINE=false         # after QA, auto re-pick the flagged shots (regenerate
#                           # keywords from the reviewer's suggestion → re-fetch →
#                           # re-rank → re-select), then re-review.
# YOUTUBE_PRIORITY_RATIO=0.7  # fraction of shots that lead with a YouTube clip
#                           # (YouTube is the preferred source). 0 disables the bias.
# Fixed policy (not configurable): YouTube *search* is yt-dlp + keywords (the
# YouTube Data API is used ONLY to drop SD clips); Shorts are never selected;
# downloads are capped at 1080p; Pexels returns 1080p-only files.
# (Pixabay and the YouTube Data API are no longer used as auto sources.)
# In the Telegram bot these source/QA/quality/refine knobs are set per-chat from
# the inline /settings menu (saved to .cache/bot_settings.json); the values above
# are just the defaults a fresh chat starts from.

# ── Ranking rate-limit tuning ────────────────────────────────────────────────
# RANK_BATCH_SIZE=6        # shots judged per LLM call
# RANK_MAX_WORKERS=3       # concurrent ranking calls (lower under rate pressure)
# RANK_JITTER_MIN=0.5      # random delay (s) before each ranking call
# RANK_JITTER_MAX=1.5      # set to 0 to disable jitter

# ── Telegram bot (optional automation) ───────────────────────────────────────
# Run `python -m bot.telegram_bot` on an always-on machine, then send the bot a
# voice/audio file to run the whole pipeline (download + FCPXML) hands-free.
# TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-BotFather
# Comma-separated numeric Telegram user id(s) allowed to trigger jobs. EMPTY =
# deny everyone (fail-closed). Message @userinfobot to find your id.
# TELEGRAM_ALLOWED_USERS=11111111,22222222
#
# Bot commands: /settings (inline menu for sources, counts, quality, QA, review
# gate), /status, /details, /download, /refine [shots] (e.g. /refine 4 9),
# /cancel, /zip, /cleanup [name|all] (disk management).
#
# Finished-project delivery: the bot attaches the clips zip to Telegram when it's
# under ~50 MB, and (when the file server below is on) also sends a signed
# download link. Enable + configure the link server:
# BOT_FILE_SERVER=1            # turn the HTTP download-link server on
# BOT_FILE_SERVER_PORT=8770    # port to serve downloads/ on (open it / map -p)
# BOT_PUBLIC_HOST=YOUR_SERVER_IP  # host/IP that goes into the link (else auto-detected)
# BOT_FILE_TOKEN_SECRET=       # optional; defaults to a hash of the bot token
#
# If Telegram is only reachable through your VPN's local proxy (common where
# Telegram is blocked), point the bot at it. Use your V2RayN/Hiddify HTTP proxy
# port. socks5 needs PySocks (in requirements.txt).
# BOT_PROXY=http://127.0.0.1:10809

# Health endpoint for orchestrators (Coolify/Docker) — lets them verify the bot
# is alive and swap containers cleanly (prevents two pollers → Telegram 409).
# On by default at port 8000. Point your Coolify health check at GET /health.
# BOT_HEALTH_PORT=8000
# BOT_HEALTH=0            # set to disable the endpoint entirely

# Telegram's Bot API limits bot file DOWNLOADS to 20 MB — a long voiceover will
# fail with "getFile 400: file is too big". To send big files, self-host a local
# Bot API server (https://github.com/tdlib/telegram-bot-api) and point the bot at
# it here to lift the cap to ~2 GB. Otherwise keep files under 20 MB (mono 64 kbps
# MP3: a ~30-min VO ≈ 14 MB).
# TELEGRAM_API_BASE=http://localhost:8081

# Route ALL app/pipeline traffic (Pexels, Pixabay, Groq, etc.) through your VPN's
# local proxy — fixes "getaddrinfo failed" DNS errors where those APIs are
# blocked. The proxy resolves DNS remotely. Use socks5h:// (not socks5://) for a
# SOCKS proxy so DNS is also resolved on the proxy side.
# APP_PROXY=http://127.0.0.1:10809

# Route ONLY YouTube (yt-dlp search + download) through a separate proxy. This is
# THE fix when the host's datacenter/cloud IP is blocked by YouTube — every
# player client returns "Video unavailable. This content isn't available." on a
# flagged IP, regardless of cookies. Use a RESIDENTIAL or mobile proxy (a second
# datacenter proxy is usually blocked too, though some work — let /test decide).
# Run /test after setting it — the YouTube-download check + client probe confirm
# whether the proxy unblocks playback. Keeps Telegram/stock/LLM traffic off the
# (often metered) proxy.
# YT_DLP_PROXY=http://user:pass@residential-proxy-host:port   # or socks5://host:port
#
# You can give a LIST (comma / space / newline separated) for backups — the pool
# is round-robined per request to spread load (handy for free proxies' bandwidth
# caps) and a download fails over to the next proxy when one is down. Cap the
# failover hops with YT_PROXY_MAX_FAILOVER (default 2).
# YT_DLP_PROXY=http://user:pass@a.proxy:6370, http://user:pass@b.proxy:6371, http://user:pass@c.proxy:6372

# Or fetch a proxy list from a URL (e.g. a ProxyScrape free list) — one
# protocol://ip:port per line. It's merged with YT_DLP_PROXY, refreshed every
# YT_DLP_PROXY_URL_TTL seconds (default 600). A free list is mostly dead/blocked,
# so the app does NOT round-robin it blindly: before each run it VALIDATES a small
# pool of proxies that actually download YouTube (with cookies, matching real
# downloads) and uses only those; dead ones are dropped and the pool is
# re-researched automatically (or via the bot's /proxies refresh). Failover also
# hops past blocked proxy IPs, so a high YT_PROXY_MAX_FAILOVER helps.
#   PROXY_POOL_SIZE        how many validated proxies to keep ready (default 5)
#   PROXY_VALIDATE_WORKERS concurrent proxy tests (default 25)
#   PROXY_VALIDATE_TIMEOUT seconds per proxy test (default 10)
#   PROXY_RESEARCH_MAX     max proxies tested per research pass (default 200)
# Reality check: free lists are slow and flaky — fine for a spare/burner YouTube
# account, but a paid residential proxy (YT_DLP_PROXY) is the reliable path.
# SECURITY: free proxies are untrusted. If you keep cookies on (to dodge the
# "Sign in to confirm you're not a bot" check), use a THROWAWAY YouTube account —
# a malicious proxy could capture that session. Use YT_DOWNLOAD_NO_COOKIES=1 to
# stay cookie-less (safer, but more bot-checks).
# YT_DLP_PROXY_URL=https://api.proxyscrape.com/v4/free-proxy-list/get?request=display_proxies&proxy_format=protocolipport&format=text
# YT_DLP_PROXY_URL_TTL=600
# YT_PROXY_MAX_FAILOVER=8
# PROXY_POOL_SIZE=5

# Set to 1 if you run a TUN-mode VPN (V2RayN, Hiddify, etc.) and hit
# "WinError 10061 / Unable to connect to proxy" errors. This strips
# stale HTTP_PROXY/HTTPS_PROXY env vars on startup so requests go
# through the OS network layer instead of a dead proxy listener.
# BROLL_BYPASS_HTTP_PROXY=1

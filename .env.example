GROQ_API_KEY=your_groq_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
# YouTube Data API v3 key (Google Cloud Console).
# Optional — enables YouTube as a search source in Director mode.
# Quota: 10,000 units/day; each search costs 100 units.
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional second Groq key — used when the first hits rate limits.
# GROQ_API_KEY_2=your_second_groq_api_key_here

# Optional free fallback when Groq is rate-limited.
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_KEY_2=your_second_openrouter_api_key_here

# Optional PAID, higher-quality model — deepseek-v4-pro routed THROUGH OpenRouter.
# Paste an OpenRouter API key here (not a direct DeepSeek key). When set it's used
# FIRST for every AI step (shot list, ranking, keywords, context segmenter), with
# Groq/OpenRouter free models as automatic fallbacks. Groq is still required (it
# does the transcription).
# DEEPSEEK_API_KEY=your_openrouter_api_key_here
# Two tiers, switched per call with the SAME key:
#   fast  → high-volume loop calls (shot slicing, ranking) — flash, no reasoning
#   smart → once-per-video global passes (topic, themes, structural pre-pass)
#           — pro WITH reasoning (synthesis). Single calls, so no rate-limit risk.
# DEEPSEEK_MODEL_FAST=deepseek/deepseek-v4-flash
# DEEPSEEK_MODEL_SMART=deepseek/deepseek-v4-pro
# Emergency override of the per-tier reasoning default (on/off). Leave unset.
# DEEPSEEK_REASONING=
# max_tokens floor (reasoning, when on, counts against it). Usually fine at 8000.
# DEEPSEEK_MAX_TOKENS=8000

# Optional — Freesound SFX download for text overlays.
# FREESOUND_API_KEY=your_freesound_api_key_here

# ── Pipeline feature toggles (default off) ───────────────────────────────────
# Context-aware keywords: pre-scan the transcript into subject segments and
# anchor each shot's queries to the subject in play at that timestamp.
# ENABLE_CONTEXT_AWARE_KEYWORDS=false
# Auto-selection: after ranking, auto-bind the top-ranked clip to each shot.
# ENABLE_AUTO_SELECTION=false
# Variety guard for auto-select: avoid reusing the same clip within this many
# recent shots (picks the next-best alternative instead). 0 disables.
# AUTO_SELECT_LOOKBACK=3
# Auto-select binds multiple clips per shot, scaled by duration (one clip per
# this many seconds), so faceless videos get a fresh visual every few seconds.
# Even short shots get MIN clips (alternatives the editor can choose from).
# AUTO_SELECT_SECONDS_PER_CLIP=5
# AUTO_SELECT_MIN_CLIPS=2
# AUTO_SELECT_MAX_CLIPS=8
# Segments per shot-list LLM call. Each block = one call, processed
# sequentially — raise this on long transcripts to cut the number of calls
# (and the rate-limit pressure / wait time). Default 20.
# DIRECTOR_BLOCK_SIZE=20

# Paid-only mode: if a DeepSeek call fails, wait & retry (longer backoff) instead
# of falling back to the free Groq/OpenRouter tiers.
# DEEPSEEK_NO_FALLBACK=true
# OpenRouter provider routing for the DeepSeek calls: only route to providers that
# support our params (json mode + reasoning), and on an empty/garbage response
# exclude that provider and retry on a different one. Set =false if you ever get
# "no available providers".
# OPENROUTER_REQUIRE_PARAMETERS=true
# OPENROUTER_PROVIDER_SORT=throughput   # optional: prefer throughput/latency/price

# ── Fully-automatic mode: which sources & how many videos per source ──────────
# AUTO_USE_PEXELS=true      # Pexels on/off (needs PEXELS_API_KEY)
# AUTO_PEXELS_NUM=3         # videos per query from Pexels
# AUTO_USE_YOUTUBE=false    # YouTube classic (yt-dlp) search on/off
# AUTO_YOUTUBE_NUM=4        # videos per query from YouTube
# AUTO_MIN_HEIGHT=720       # minimum height (HD); 0 = no filter
# ENABLE_QA_REVIEW=true     # run the Step 5.5 QA review in auto/headless mode (false skips it)
# (Pixabay and the YouTube Data API are no longer used as auto sources.)

# ── Ranking rate-limit tuning ────────────────────────────────────────────────
# RANK_BATCH_SIZE=6        # shots judged per LLM call
# RANK_MAX_WORKERS=3       # concurrent ranking calls (lower under rate pressure)
# RANK_JITTER_MIN=0.5      # random delay (s) before each ranking call
# RANK_JITTER_MAX=1.5      # set to 0 to disable jitter

# ── Telegram bot (optional automation) ───────────────────────────────────────
# Run `python -m bot.telegram_bot` on an always-on machine, then send the bot a
# voice/audio file to run the whole pipeline (download + FCPXML) hands-free.
# TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-BotFather
# Comma-separated numeric Telegram user id(s) allowed to trigger jobs. EMPTY =
# deny everyone (fail-closed). Message @userinfobot to find your id.
# TELEGRAM_ALLOWED_USERS=11111111,22222222
# If Telegram is only reachable through your VPN's local proxy (common where
# Telegram is blocked), point the bot at it. Use your V2RayN/Hiddify HTTP proxy
# port. socks5 needs PySocks (in requirements.txt).
# BOT_PROXY=http://127.0.0.1:10809

# Route ALL app/pipeline traffic (Pexels, Pixabay, Groq, etc.) through your VPN's
# local proxy — fixes "getaddrinfo failed" DNS errors where those APIs are
# blocked. The proxy resolves DNS remotely. Use socks5h:// (not socks5://) for a
# SOCKS proxy so DNS is also resolved on the proxy side.
# APP_PROXY=http://127.0.0.1:10809

# Set to 1 if you run a TUN-mode VPN (V2RayN, Hiddify, etc.) and hit
# "WinError 10061 / Unable to connect to proxy" errors. This strips
# stale HTTP_PROXY/HTTPS_PROXY env vars on startup so requests go
# through the OS network layer instead of a dead proxy listener.
# BROLL_BYPASS_HTTP_PROXY=1

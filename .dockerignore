# Keep the build context (and image) small and free of secrets.
.git
.gitignore
.dockerignore
Dockerfile

# Secrets & local config — pass these at runtime via --env-file instead.
.env
.env.*
!.env.example
# YouTube cookies — never bake into the image. Upload via the bot (persisted to
# the mounted .cache/cookies.txt) or mount at runtime.
cookies/
cookies.txt
*cookies*.txt

# Local runtime state — recreated in the container / on volumes.
venv/
.cache/
downloads/
__pycache__/
**/__pycache__/
*.pyc

# Node / Remotion build artifacts — deps are installed inside the image.
node_modules/
**/node_modules/
remotion/out/
remotion/.remotion/

# Dev-only / docs — not needed at runtime.
tests/
scratch/
*.pdf
*.docx
prd_*.txt
*.zip
run.bat
run.sh
start_bot.bat
